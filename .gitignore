# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*.aux
*.log
*.out
img.jpeg

# working / prep files (never commit)
FIX-PROMPT.md
ALIGNMENT-PROMPT.md
# root PDFs (the public CV lives at public/resume.pdf)
/*.pdf
compass_artifact_*.md
unnamed.jpg

# editor
.idea/
